@startuml use-cases
!theme plain
skinparam actor {
  BackgroundColor #FFF3E0
}
skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}

title Functional Workflow — SRS Review Agent

note top
  This diagram shows functional workflow steps.
  For the ROI-based use case taxonomy (UC1–UC7)
  see docs/01-system/use-cases/
end note

actor "🟦 Regulatory Lead" as Reg
actor "🟨 Document Owner\n(Risk/UX/Cyber/AI)" as DocOwner
actor "🟢 SRS Owner" as SRSOwner
actor "QA/Reg" as QA
actor "🟦 RA/PRRC" as RA

rectangle "SRS Review Agent" {
  usecase (Submit baseline\ndocument) as SubmitBaseline
  usecase (Review SRS\nsuggestions) as ReviewSuggestions
  usecase (Monitor document\nchange events) as MonitorChanges
  usecase (Classify change\ntype and impact) as ClassifyChange
  usecase (Generate citation-\nbacked findings) as GenerateFindings
  usecase (Review and\ndisposition findings) as ReviewFindings
  usecase (Escalate or\nclose findings) as CloseFindings
}

Reg ..> SubmitBaseline
DocOwner ..> SubmitBaseline
SRSOwner ..> ReviewSuggestions
SRSOwner ..> MonitorChanges
MonitorChanges ..> ClassifyChange : <<include>>
ClassifyChange ..> GenerateFindings : <<include>>
GenerateFindings ..> ReviewFindings
DocOwner ..> ReviewFindings
RA ..> ReviewFindings
QA ..> CloseFindings

note bottom
  Baseline → SRS suggestions
  SRS changes → owner findings
  All findings require human disposition
end note

@enduml
