@startuml doc-relationships
!theme plain
skinparam rectangle {
  BackgroundColor #F3E5F5
}

title Document Relationships

package "🟦 Static Baseline" {
  [Intended Use]
  [Classification]
}

package "🟨 Dynamic Upstream" {
  [Risk File]
  [UX File]
  [Cyber File]
  [AI Docs]
  [Clinical Eval]
}

rectangle "🟢 SRS\n(Central Hub)" as SRS

package "Architecture" {
  [Software Architecture\nDocument (SAD)]
}

package "Downstream" {
  [V&V Plans]
  [IFU]
  [Tech Doc]
}

[Intended Use] --> SRS : scope / claims
[Classification] --> SRS : risk level / IMDRF category
[Risk File] --> SRS : risk controls
[UX File] --> SRS : UI requirements
[Cyber File] --> SRS : security requirements
[AI Docs] --> SRS : performance targets
[Clinical Eval] --> SRS : clinical claims

[Software Architecture\nDocument (SAD)] --> SRS : software item safety class
SRS --> [Software Architecture\nDocument (SAD)] : primary driver

SRS ..> [Risk File] : 🔴 safety changes
SRS ..> [UX File] : 🔴 U