@startuml functional-components
!theme aws-orange
title Functional Components

package "SRS Review Agent" {
  component [Event\nReceiver] as Webhook
  component [SRS Parser\n& Diff] as Parser
  component [Change\nClassifier] as Classifier
  component [Traceability\nResolver] as Resolver
  component [Findings\nGenerator] as Findings
  component [Notification\nRouter] as Router
  database [Config DB\n(Table 1,2,3)] as Config
}

cloud "Document Repository /\nVersion Control" as DocRepo
database "Document\nManagement\nSystem" as DMS

DocRepo --> Webhook
Webhook --> Parser
Parser --> Classifier
Classifier --> Resolver
Resolver --> Config
Resolver --> DMS
Resolver --> Findings
Findings --> Router
Router --> Config

note right of Config
  Tables 1,2,3 as JSON/YAML
end note

note right of Config
  Tables 1,2,3 as structured config
  - IMDRF category per product
  - IEC 62304 safety class per item
end note

@enduml